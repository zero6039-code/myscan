{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dewsecure",
  "main": "worker.js",                      // ← 新增：指定 Worker 入口文件
  "compatibility_date": "2026-06-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"                     // ← 新增：绑定静态资源，Worker 中通过 env.ASSETS.fetch 访问
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
